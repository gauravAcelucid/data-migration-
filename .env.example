# ===== AWS S3 =====
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# ===== PostgreSQL =====
PG_HOST=your-postgres-host
PG_PORT=5432
PG_DATABASE=your-database
PG_USERNAME=your-username
PG_PASSWORD=your-password
PG_SSLMODE=require

# ===== MongoDB =====
MONGO_URL=mongodb://your-mongo-host:27017
MONGO_DATABASE=your-database
MONGO_COLLECTION=your-collection

# ===== Metadata Database (local PostgreSQL for storing connection configs) =====
METADATA_DATABASE_URL=postgresql://postgres:pass@localhost:5432/tableName
